#encoding utf-8
#
# ATtiny85-20PU-MCU_Microchip_ATtiny
#
DEF ATtiny85-20PU-MCU_Microchip_ATtiny U 0 20 Y Y 1 F N
F0 "U" -500 550 50 H V L BNN
F1 "ATtiny85-20PU-MCU_Microchip_ATtiny" 100 -550 50 H V L TNN
